{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "api-tests/playwright/**/*.ts",
    "ui-tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}